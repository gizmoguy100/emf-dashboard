# Copy to .env for local development. Do not commit .env.

# Keep .env small. Put app settings and secrets in config/config.yaml.
APP_CONFIG_FILE=/app/config/config.yaml

# Compose uses this for local port publishing.
APP_HTTP_PORT=8080

# PostgreSQL local development defaults.
POSTGRES_DB=emf_dashboard
POSTGRES_USER=emf_dashboard
POSTGRES_PASSWORD=change-me-local-only
